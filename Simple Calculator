#SIMPLE CALCULATOR
print('1.Addition')
print('2.Subtraction')
print('3.Multiplication')
print('4.Division')
choice=int(input('Enter a choice:'))
num1=int(input('Enter a num1:'))
num2=int(input('Enter a num2:'))
if choice==1:
  print('Result=',num1+num2)
elif choice==2:
  print('Result=',num1-num2)
elif choice==3:
  print('Result=',num1*num2)
elif choice==4:
  print('Result=',num1/num2)
else:
   print('invalid choice')


  
